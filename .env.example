# Sync_Plex secrets — the real .env here is a symlink to
# ../personal_credentials/personal.env. Each variable name is referenced from
# the inventory (../personal_credentials/hosts.json) via the service's
# api_key_env field, so adding a new instance means adding a service entry
# there and a matching key in the env file. Never commit real values.

# --- Sonarr (Settings > General > API Key) ---
SONARR_BEHEMOTH_API_KEY=
SONARR_ELITEDESK_API_KEY=

# --- Radarr (Settings > General > API Key) ---
RADARR_BEHEMOTH_API_KEY=
RADARR_BEHEMOTH_4K_API_KEY=
RADARR_ELITEDESK_API_KEY=

# --- Plex (X-Plex-Token, account-level: one token works on every server
#     signed into your account — both plex services reference this) ---
PLEX_TOKEN=

# --- Web UI login (generate with: openssl rand -base64 32) ---
# Signs session cookies; without it a random per-boot secret is used and
# every restart logs everyone out. Accounts themselves live in the data dir
# (users.json) via `syncplex users add ...`, not here.
SYNCPLEX_SESSION_SECRET=
